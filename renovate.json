{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track the trove kolla image tag as the chart appVersion",
      "managerFilePatterns": ["/(^|\\/)Chart\\.yaml$/"],
      "matchStrings": ["appVersion:\\s*[\"']?(?<currentValue>[^\\s\"']+)"],
      "depNameTemplate": "registry.rc.nectar.org.au/kolla/ubuntu-source-trove-api",
      "datasourceTemplate": "docker",
      "versioningTemplate": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-(?<build>\\d+)-g[0-9a-f]+-\\d+-(?<revision>\\d+)$"
    }
  ],
  "packageRules": [
    {
      "description": "Bump chart version when appVersion changes: major image upgrade bumps chart major, anything else bumps patch",
      "matchManagers": ["custom.regex"],
      "matchPackageNames": ["registry.rc.nectar.org.au/kolla/ubuntu-source-trove-api"],
      "commitMessageTopic": "appVersion",
      "bumpVersions": [
        {
          "name": "chart-version",
          "filePatterns": ["Chart.yaml"],
          "matchStrings": ["(^|\\n)version:\\s*(?<version>[^\\s]+)"],
          "bumpType": "{{#if isMajor}}major{{else}}patch{{/if}}"
        }
      ]
    }
  ]
}
